# .env.example

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Opera PMS Configuration
OPERA_PMS_URL=http://your_opera_pms_url
OPERA_PMS_USERNAME=your_opera_pms_username
OPERA_PMS_PASSWORD=your_opera_pms_password

# MikroTik Configuration
MIKROTIK_HOST=your_mikrotik_host
MIKROTIK_USER=your_mikrotik_username
MIKROTIK_PASSWORD=your_mikrotik_password

# FreeRADIUS Configuration
FREERADIUS_HOST=localhost
FREERADIUS_PORT=1812
FREERADIUS_SECRET=your_freeradius_secret

# Email Configuration
EMAIL_HOST=smtp.your_email_provider.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email_username
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@example.com
